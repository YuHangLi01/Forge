# Install: sudo cp deploy/sudoers-forge /etc/sudoers.d/forge && sudo chmod 440 /etc/sudoers.d/forge
# Allows the deploy user to restart Forge services without a password prompt.
forge ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart forge-api
forge ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart forge-worker
forge ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart forge-chromadb
forge ALL=(ALL) NOPASSWD: /usr/bin/journalctl -u forge-api *
forge ALL=(ALL) NOPASSWD: /usr/bin/journalctl -u forge-worker *
