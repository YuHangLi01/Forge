# =========================================================
# Forge — 环境变量示例
# 复制为 .env 并填入真实值,不要提交 .env 到版本控制
# =========================================================

# ---- 飞书应用配置 ----------------------------------------
# 飞书开发者后台 → 应用信息 → App ID
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# 飞书开发者后台 → 应用信息 → App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 飞书事件订阅 → Verification Token
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 飞书事件订阅 → Encrypt Key (开启加密时填写)
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 飞书 OpenAPI 域名,默认不需要修改
FEISHU_DOMAIN=https://open.feishu.cn

# ---- 豆包 / 火山方舟 LLM ---------------------------------
# 火山方舟控制台 → API Key
DOUBAO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 火山方舟 API 地址,末尾不要加 /v1
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 豆包 Pro 推理接入点 ID (ep-xxx 格式)
DOUBAO_MODEL_PRO=ep-20241230000000-xxxxx
# 豆包 Lite 推理接入点 ID (低成本任务使用)
DOUBAO_MODEL_LITE=ep-20241230000000-yyyyy

# ---- 火山引擎语音识别 ASR --------------------------------
# 火山引擎控制台 → 语音技术 → App ID
VOLC_ASR_APP_ID=xxxxxxxxxx
# 火山引擎 ASR Access Token
VOLC_ASR_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ASR 集群 ID,默认一句话识别集群
VOLC_ASR_CLUSTER=volcengine_input_common

# ---- PostgreSQL -----------------------------------------
# 异步驱动,供 FastAPI / LangGraph 使用
DATABASE_URL=postgresql+psycopg://forge:yourpassword@localhost:5432/forge
# 同步驱动,供 Alembic 迁移使用 (驱动相同,psycopg3 同时支持同步异步)
DATABASE_URL_SYNC=postgresql+psycopg://forge:yourpassword@localhost:5432/forge

# ---- Redis ----------------------------------------------
# Celery broker 与 result backend
REDIS_URL=redis://localhost:6379/0

# ---- ChromaDB -------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=forge_docs

# ---- 应用配置 --------------------------------------------
# 运行环境: dev | staging | prod
APP_ENV=dev
# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ---- Celery 配置 -----------------------------------------
CELERY_TASK_TIME_LIMIT=180
CELERY_TASK_SOFT_TIME_LIMIT=150
CELERY_WORKER_CONCURRENCY=4

# ---- PostgreSQL Docker 密码 (docker-compose 使用) --------
POSTGRES_PASSWORD=yourpassword
